{
    "manifest_version": 3,
    "name": "__MSG_ext_name__",
    "short_name": "DRISHTI",
    "version": "2.1.0",
    "description": "__MSG_ext_description__",
    "default_locale": "en",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "DRISHTI — Deepfake Detector",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://meet.google.com/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/overlay.css"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "permissions": [
        "activeTab",
        "storage",
        "alarms",
        "tabs",
        "tts",
        "scripting"
    ],
    "host_permissions": [
        "https://meet.google.com/*",
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*",
                "content/overlay.css",
                "content/content.js"
            ],
            "matches": [
                "https://meet.google.com/*"
            ]
        }
    ]
}